# Copy this file to .env to configure your local GNOMAN 2.0 environment.

# ─── RPC / Network ────────────────────────────────────────────────────────────
# Ethereum JSON-RPC endpoint. Can also be stored in KWallet/keyring via the
# Keyring page using key "GNOMAN_RPC_URL" — .env and keyring both work.
GNOMAN_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
# SAFE_RPC_URL=  # alias — either key works
# RPC_URL=       # lowest-priority alias

# ─── Etherscan (optional — enables source fetching in Dev Tools) ──────────────
# ETHERSCAN_API_KEY=YOUR_KEY

# ─── Safe config overrides (optional) ─────────────────────────────────────────
# SAFE_CONFIG_PATH=/path/to/safes.json
# SAFE_MODE_ENABLED=true

# ─── Electron / build ─────────────────────────────────────────────────────────
NODE_ENV=development
VITE_DEV_SERVER_URL=http://localhost:5173
